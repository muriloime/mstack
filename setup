#!/usr/bin/env bash
# mstack setup — build browser binary + register skills with Claude Code / Codex
set -e
umask 077  # Restrict new files to owner-only (0o600 files, 0o700 dirs)

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

INSTALL_MSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_MSTACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_MSTACK_DIR")"
BROWSE_BIN="$SOURCE_MSTACK_DIR/browse/dist/browse"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_MSTACK="$CODEX_SKILLS/mstack"
FACTORY_SKILLS="$HOME/.factory/skills"
FACTORY_MSTACK="$FACTORY_SKILLS/mstack"
OPENCODE_SKILLS="$HOME/.config/opencode/skills"
OPENCODE_MSTACK="$OPENCODE_SKILLS/mstack"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Symlink-or-copy helper ───────────────────────────────────
# On macOS/Linux: create a symlink (existing behavior).
# On Windows without Developer Mode (MSYS2/Git Bash): plain ln -snf silently
# creates a frozen file copy that doesn't refresh after `git pull`. We use
# explicit `cp -R` / `cp -f` so the user gets a real copy and the staleness
# is reportable (re-run ./setup after pull). Auto-detects file vs dir.
#
# INVARIANT: every symlink in this script MUST route through this helper.
# A raw ln call here will be caught by test/setup-windows-fallback.test.ts
# (the static-invariant assertion D7).
_link_or_copy() {
  local src="$1"
  local dst="$2"
  if [ "$IS_WINDOWS" -eq 1 ]; then
    rm -rf "$dst"
    # On Windows, skip sources that don't resolve on disk (plain `ln -snf` of
    # a name-only or relative path has no Windows equivalent).
    if [ ! -e "$src" ]; then
      return 0
    fi
    if [ -d "$src" ]; then
      cp -R "$src" "$dst"
    else
      cp -f "$src" "$dst"
    fi
  else
    ln -snf "$src" "$dst"
  fi
}

_WINDOWS_COPY_NOTE_PRINTED=0
_print_windows_copy_note_once() {
  if [ "$IS_WINDOWS" -eq 1 ] && [ "$_WINDOWS_COPY_NOTE_PRINTED" -eq 0 ]; then
    echo "  note: Windows install uses file copies (no Developer Mode required). Re-run ./setup after every 'git pull' to refresh skill files."
    _WINDOWS_COPY_NOTE_PRINTED=1
  fi
}

# ─── Quiet mode helper ────────────────────────────────────────
QUIET=0
log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

# ─── Parse flags ──────────────────────────────────────────────
HOST="claude"
LOCAL_INSTALL=0
SKILL_PREFIX=1
SKILL_PREFIX_FLAG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected claude, codex, kiro, factory, opencode, openclaw, hermes, gbrain, or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix)    SKILL_PREFIX=1; SKILL_PREFIX_FLAG=1; shift ;;
    --no-prefix) SKILL_PREFIX=0; SKILL_PREFIX_FLAG=1; shift ;;
    -q|--quiet) QUIET=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|kiro|factory|opencode|auto) ;;
  openclaw)
    echo ""
    echo "OpenClaw integration uses a different model — OpenClaw spawns Claude Code"
    echo "sessions natively via ACP. mstack provides methodology artifacts, not a"
    echo "full skill installation."
    echo ""
    echo "To integrate mstack with OpenClaw:"
    echo "  1. Tell your OpenClaw agent: 'install mstack for openclaw'"
    echo "  2. Or generate artifacts: bun run gen:skill-docs --host openclaw"
    echo "  3. See docs/OPENCLAW.md for the full architecture"
    echo ""
    exit 0 ;;
  hermes)
    echo ""
    echo "Hermes integration uses the same model as OpenClaw — Hermes spawns"
    echo "Claude Code sessions, and mstack provides methodology artifacts."
    echo ""
    echo "To integrate mstack with Hermes:"
    echo "  1. Tell your Hermes agent: 'install mstack for hermes'"
    echo "  2. Or generate artifacts: bun run gen:skill-docs --host hermes"
    echo ""
    exit 0 ;;
  gbrain)
    echo ""
    echo "GBrain is a mod for mstack — it makes coding skills brain-aware."
    echo "GBrain generates brain-enhanced skill variants that search your brain"
    echo "for context before starting and save results after finishing."
    echo ""
    echo "To generate brain-aware skills:"
    echo "  bun run gen:skill-docs --host gbrain"
    echo ""
    echo "GBrain setup and brain skills ship from the GBrain repo."
    echo ""
    exit 0 ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, kiro, factory, opencode, openclaw, hermes, gbrain, or auto)" >&2; exit 1 ;;
esac

# ─── Resolve skill prefix preference ─────────────────────────
# Priority: CLI flag > saved config > interactive prompt (or flat default for non-TTY)
MSTACK_CONFIG="$SOURCE_MSTACK_DIR/bin/mstack-config"
export MSTACK_SETUP_RUNNING=1  # Prevent mstack-config post-set hook from triggering relink mid-setup
if [ "$SKILL_PREFIX_FLAG" -eq 0 ]; then
  _saved_prefix="$("$MSTACK_CONFIG" get skill_prefix 2>/dev/null || true)"
  if [ "$_saved_prefix" = "true" ]; then
    SKILL_PREFIX=1
  elif [ "$_saved_prefix" = "false" ]; then
    SKILL_PREFIX=0
  else
    # No saved preference — prompt interactively (or default flat for non-TTY/quiet)
    if [ "$QUIET" -eq 1 ]; then
      SKILL_PREFIX=0
    elif [ -t 0 ]; then
      echo ""
      echo "Skill naming: how should mstack skills appear?"
      echo ""
      echo "  1) Short names: /qa, /ship, /review"
      echo "     Recommended. Clean and fast to type."
      echo ""
      echo "  2) Namespaced: /mstack-qa, /mstack-ship, /mstack-review"
      echo "     Use this if you run other skill packs alongside mstack to avoid conflicts."
      echo ""
      printf "Choice [1/2] (default: 1, auto-selects in 10s): "
      read -t 10 -r _prefix_choice </dev/tty 2>/dev/null || _prefix_choice=""
      case "$_prefix_choice" in
        2) SKILL_PREFIX=1 ;;
        *) SKILL_PREFIX=0 ;;
      esac
    else
      SKILL_PREFIX=0
    fi
    # Save the choice for future runs
    "$MSTACK_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
  fi
else
  # Flag was passed explicitly — persist the choice
  "$MSTACK_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
fi

# --local: install to .claude/skills/ in the current working directory (deprecated)
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  echo "Warning: --local is deprecated. Use global install + --team instead." >&2
  echo "  See: https://github.com/garrytan/gstack#team-mode" >&2
  if [ "$HOST" = "codex" ]; then
    echo "Error: --local is only supported for Claude Code (not Codex)." >&2
    exit 1
  fi
  INSTALL_SKILLS_DIR="$(pwd)/.claude/skills"
  mkdir -p "$INSTALL_SKILLS_DIR"
  HOST="claude"
  INSTALL_CODEX=0
fi

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_KIRO=0
INSTALL_FACTORY=0
INSTALL_OPENCODE=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  command -v droid >/dev/null 2>&1 && INSTALL_FACTORY=1
  command -v opencode >/dev/null 2>&1 && INSTALL_OPENCODE=1
  # If none found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ] && [ "$INSTALL_FACTORY" -eq 0 ] && [ "$INSTALL_OPENCODE" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
elif [ "$HOST" = "factory" ]; then
  INSTALL_FACTORY=1
elif [ "$HOST" = "opencode" ]; then
  INSTALL_OPENCODE=1
fi

migrate_direct_codex_install() {
  local mstack_dir="$1"
  local codex_mstack="$2"
  local migrated_dir="$HOME/.mstack/repos/mstack"

  [ "$mstack_dir" = "$codex_mstack" ] || return 0
  [ -L "$mstack_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$mstack_dir" ]; then
    echo "mstack setup failed: direct Codex install detected at $mstack_dir" >&2
    echo "A migrated repo already exists at $migrated_dir; move one of them aside and rerun setup." >&2
    exit 1
  fi

  log "Migrating direct Codex install to $migrated_dir to avoid duplicate skill discovery..."
  mv "$mstack_dir" "$migrated_dir"
  SOURCE_MSTACK_DIR="$migrated_dir"
  INSTALL_MSTACK_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_MSTACK_DIR")"
  BROWSE_BIN="$SOURCE_MSTACK_DIR/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_MSTACK_DIR" "$CODEX_MSTACK"
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Bun can't launch Chromium due to broken pipe handling
    # (oven-sh/bun#4253). Use Node.js to verify Chromium works instead.
    (
      cd "$SOURCE_MSTACK_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_MSTACK_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_MSTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_MSTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_MSTACK_DIR/bun.lock" ] && [ "$SOURCE_MSTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  log "Building browse binary..."
  (
    cd "$SOURCE_MSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$SOURCE_MSTACK_DIR/browse/dist/.version" ]; then
    git -C "$SOURCE_MSTACK_DIR" rev-parse HEAD > "$SOURCE_MSTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi

  # macOS Apple Silicon: ad-hoc codesign compiled binaries.
  # Bun's --compile can produce a corrupt or linker-only code signature that
  # macOS kills with SIGKILL (exit 137). The two-step remove+re-sign is
  # required because a naive `codesign -s - -f` fails when the existing
  # signature block is corrupt. This is idempotent and costs <1s.
  # See: https://github.com/garrytan/gstack/issues/997
  if [ "$(uname -s)" = "Darwin" ] && [ "$(uname -m)" = "arm64" ]; then
    for _bin in browse/dist/browse browse/dist/find-browse design/dist/design make-pdf/dist/pdf bin/mstack-global-discover; do
      _bin_path="$SOURCE_MSTACK_DIR/$_bin"
      [ -f "$_bin_path" ] && [ -x "$_bin_path" ] || continue
      codesign --remove-signature "$_bin_path" 2>/dev/null || true
      if ! codesign -s - -f "$_bin_path" 2>/dev/null; then
        log "warning: codesign failed for $_bin (binary may not run on Apple Silicon)"
      fi
    done
  fi

  # macOS: install coreutils for `gtimeout` (Codex hang protection in /codex + /autoplan).
  # macOS ships BSD `timeout`-less; Homebrew's coreutils installs GNU timeout as
  # `gtimeout` to avoid shadowing BSD utilities. The /codex and /autoplan skills
  # fall back to unwrapped codex invocations when neither is available — this
  # auto-install upgrades them to hang-protected where possible.
  # Skip entirely with MSTACK_SKIP_COREUTILS=1 (CI, managed machines, offline envs).
  if [ "$(uname -s)" = "Darwin" ] && [ "${MSTACK_SKIP_COREUTILS:-0}" != "1" ]; then
    if ! command -v gtimeout >/dev/null 2>&1 && ! command -v timeout >/dev/null 2>&1; then
      if command -v brew >/dev/null 2>&1; then
        log "Installing coreutils for Codex hang protection (set MSTACK_SKIP_COREUTILS=1 to skip)..."
        brew install coreutils >/dev/null 2>&1 || log "warning: brew install coreutils failed; /codex will run without hang protection"
      else
        log "warning: Homebrew not found. /codex will run without hang protection. Install coreutils manually or set MSTACK_SKIP_COREUTILS=1."
      fi
    fi
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "mstack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 1b. Generate .agents/ Codex skill docs — always regenerate to prevent stale descriptions.
# .agents/ is no longer committed — generated at setup time from .tmpl templates.
# bun run build already does this, but we need it when NEEDS_BUILD=0 (binary is fresh).
# Always regenerate: generation is fast (<2s) and mtime-based staleness checks are fragile
# (miss stale files when timestamps match after clone/checkout/upgrade).
AGENTS_DIR="$SOURCE_MSTACK_DIR/.agents/skills"
NEEDS_AGENTS_GEN=1

if [ "$NEEDS_AGENTS_GEN" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .agents/ skill docs..."
  (
    cd "$SOURCE_MSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host codex
  )
fi

# 1c. Generate .factory/ Factory Droid skill docs
if [ "$INSTALL_FACTORY" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .factory/ skill docs..."
  (
    cd "$SOURCE_MSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host factory
  )
fi

# 1d. Generate .opencode/ OpenCode skill docs
if [ "$INSTALL_OPENCODE" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .opencode/ skill docs..."
  (
    cd "$SOURCE_MSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host opencode
  )
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SOURCE_MSTACK_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Node.js launches Chromium (not Bun — see oven-sh/bun#4253).
    # Ensure playwright is importable by Node from the mstack directory.
    if ! command -v node >/dev/null 2>&1; then
      echo "mstack setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$SOURCE_MSTACK_DIR"
      # Bun's node_modules already has playwright; verify Node can require it
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
      # @ngrok/ngrok is externalized in server-node.mjs and resolved at runtime.
      # Verify the platform-specific native binary is installed so /pair-agent
      # tunnels don't fail later with a cryptic module-not-found error.
      node -e "require('@ngrok/ngrok')" 2>/dev/null || npm install --no-save @ngrok/ngrok
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "mstack setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and 'node -e \"require('playwright')\"' works." >&2
  else
    echo "mstack setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

# 3. Ensure ~/.mstack global state directory exists
mkdir -p "$HOME/.mstack/projects"

# ─── Helper: link Claude skill subdirectories into a skills parent directory ──
# Creates real directories (not symlinks) at the top level with a SKILL.md symlink
# inside. This ensures Claude discovers them as top-level skills, not nested under
# mstack/ (which would auto-prefix them as mstack-*).
# When SKILL_PREFIX=1, directories are prefixed with "mstack-".
# Use --no-prefix to restore flat names.
link_claude_skill_dirs() {
  local mstack_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_dir in "$mstack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      dir_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$dir_name" = "node_modules" ] && continue
      # Use frontmatter name: if present (e.g., run-tests/ with name: test → symlink as "test")
      skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
      [ -z "$skill_name" ] && skill_name="$dir_name"
      # Apply mstack- prefix unless --no-prefix or already prefixed
      if [ "$SKILL_PREFIX" -eq 1 ]; then
        case "$skill_name" in
          mstack-*) link_name="$skill_name" ;;
          *)        link_name="mstack-$skill_name" ;;
        esac
      else
        link_name="$skill_name"
      fi
      target="$skills_dir/$link_name"
      # Upgrade old directory symlinks to real directories
      if [ -L "$target" ]; then
        rm -f "$target"
      fi
      # Create real directory with symlinked SKILL.md (absolute path)
      # Use mkdir -p unconditionally (idempotent) to avoid TOCTOU race
      mkdir -p "$target"
      # Validate target isn't a symlink before creating the link
      if [ -L "$target/SKILL.md" ]; then rm "$target/SKILL.md"; fi
      _link_or_copy "$mstack_dir/$dir_name/SKILL.md" "$target/SKILL.md"
      linked+=("$link_name")
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
    _print_windows_copy_note_once
  fi
}

# ─── Helper: remove old unprefixed Claude skill entries ───────────────────────
# Migration: when switching from flat names to mstack- prefixed names,
# clean up stale symlinks or directories that point into the mstack directory.
cleanup_old_claude_symlinks() {
  local mstack_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$mstack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Skip already-prefixed dirs (mstack-upgrade) — no old symlink to clean
      case "$skill_name" in mstack-*) continue ;; esac
      old_target="$skills_dir/$skill_name"
      # Remove directory symlinks pointing into mstack/
      if [ -L "$old_target" ]; then
        link_dest="$(readlink "$old_target" 2>/dev/null || true)"
        case "$link_dest" in
          mstack/*|*/mstack/*)
            rm -f "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      # Remove real directories with symlinked SKILL.md pointing into mstack/
      elif [ -d "$old_target" ] && [ -L "$old_target/SKILL.md" ]; then
        link_dest="$(readlink "$old_target/SKILL.md" 2>/dev/null || true)"
        case "$link_dest" in
          *mstack*)
            rm -rf "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      # Windows install pattern: real dir with real-file SKILL.md (no symlink
      # available, so we can't readlink to verify provenance). The outer loop
      # iterates known mstack skill names from "$mstack_dir"/*, so a name match
      # plus IS_WINDOWS is safe to treat as mstack-managed during a mode flip.
      elif [ "$IS_WINDOWS" -eq 1 ] && [ -d "$old_target" ] && [ -f "$old_target/SKILL.md" ]; then
        rm -rf "$old_target"
        removed+=("$skill_name")
      fi
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up old entries: ${removed[*]}"
  fi
}

# ─── Helper: remove old prefixed Claude skill entries ─────────────────────────
# Reverse migration: when switching from mstack- prefixed names to flat names,
# clean up stale mstack-* symlinks or directories that point into the mstack directory.
cleanup_prefixed_claude_symlinks() {
  local mstack_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$mstack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Only clean up prefixed entries for dirs that AREN'T already prefixed
      # (e.g., remove mstack-qa but NOT mstack-upgrade which is the real dir name)
      case "$skill_name" in mstack-*) continue ;; esac
      prefixed_target="$skills_dir/mstack-$skill_name"
      # Remove directory symlinks pointing into mstack/
      if [ -L "$prefixed_target" ]; then
        link_dest="$(readlink "$prefixed_target" 2>/dev/null || true)"
        case "$link_dest" in
          mstack/*|*/mstack/*)
            rm -f "$prefixed_target"
            removed+=("mstack-$skill_name")
            ;;
        esac
      # Remove real directories with symlinked SKILL.md pointing into mstack/
      elif [ -d "$prefixed_target" ] && [ -L "$prefixed_target/SKILL.md" ]; then
        link_dest="$(readlink "$prefixed_target/SKILL.md" 2>/dev/null || true)"
        case "$link_dest" in
          *mstack*)
            rm -rf "$prefixed_target"
            removed+=("mstack-$skill_name")
            ;;
        esac
      # Windows install pattern: real dir with real-file SKILL.md. Same
      # reasoning as cleanup_old_claude_symlinks — directory name match plus
      # IS_WINDOWS is safe during a mode flip.
      elif [ "$IS_WINDOWS" -eq 1 ] && [ -d "$prefixed_target" ] && [ -f "$prefixed_target/SKILL.md" ]; then
        rm -rf "$prefixed_target"
        removed+=("mstack-$skill_name")
      fi
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up prefixed entries: ${removed[*]}"
  fi
}

# ─── Helper: link generated Codex skills into a skills parent directory ──
# Installs from .agents/skills/mstack-* (the generated Codex-format skills)
# instead of source dirs (which have Claude paths).
link_codex_skill_dirs() {
  local mstack_dir="$1"
  local skills_dir="$2"
  local agents_dir="$mstack_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  Generating .agents/ skill docs..."
    ( cd "$mstack_dir" && bun run gen:skill-docs --host codex )
  fi

  if [ ! -d "$agents_dir" ]; then
    echo "  warning: .agents/skills/ generation failed — run 'bun run gen:skill-docs --host codex' manually" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/mstack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip the sidecar directory — it contains runtime asset symlinks (bin/,
      # browse/), not a skill. Linking it would overwrite the root mstack
      # symlink that Step 5 already pointed at the repo root.
      [ "$skill_name" = "mstack" ] && continue
      target="$skills_dir/$skill_name"
      # Create or update symlink
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        _link_or_copy "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: create .agents/skills/mstack/ sidecar symlinks ──────────
# Codex/Gemini/Cursor read skills from .agents/skills/. We link runtime
# assets (bin/, browse/dist/, review/, qa/, etc.) so skill templates can
# resolve paths like $SKILL_ROOT/review/design-checklist.md.
create_agents_sidecar() {
  local repo_root="$1"
  local agents_mstack="$repo_root/.agents/skills/mstack"
  mkdir -p "$agents_mstack"

  # Sidecar directories that skills reference at runtime
  for asset in bin browse review qa; do
    local src="$SOURCE_MSTACK_DIR/$asset"
    local dst="$agents_mstack/$asset"
    if [ -d "$src" ] || [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        _link_or_copy "$src" "$dst"
      fi
    fi
  done

  # Sidecar files that skills reference at runtime
  for file in ETHOS.md; do
    local src="$SOURCE_MSTACK_DIR/$file"
    local dst="$agents_mstack/$file"
    if [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        _link_or_copy "$src" "$dst"
      fi
    fi
  done
}

# ─── Helper: create a minimal ~/.codex/skills/mstack runtime root ───────────
# Codex scans ~/.codex/skills recursively. Exposing the whole repo here causes
# duplicate skills because source SKILL.md files and generated Codex skills are
# both discoverable. Keep this directory limited to runtime assets + root skill.
create_codex_runtime_root() {
  local mstack_dir="$1"
  local codex_mstack="$2"
  local agents_dir="$mstack_dir/.agents/skills"

  if [ -L "$codex_mstack" ]; then
    rm -f "$codex_mstack"
  elif [ -d "$codex_mstack" ] && [ "$codex_mstack" != "$mstack_dir" ]; then
    # Old direct installs left a real directory here with stale source skills.
    # Remove it so we start fresh with only the minimal runtime assets.
    rm -rf "$codex_mstack"
  fi

  mkdir -p "$codex_mstack" "$codex_mstack/browse" "$codex_mstack/mstack-upgrade" "$codex_mstack/review"

  if [ -f "$agents_dir/mstack/SKILL.md" ]; then
    _link_or_copy "$agents_dir/mstack/SKILL.md" "$codex_mstack/SKILL.md"
  fi
  if [ -d "$mstack_dir/bin" ]; then
    _link_or_copy "$mstack_dir/bin" "$codex_mstack/bin"
  fi
  if [ -d "$mstack_dir/browse/dist" ]; then
    _link_or_copy "$mstack_dir/browse/dist" "$codex_mstack/browse/dist"
  fi
  if [ -d "$mstack_dir/browse/bin" ]; then
    _link_or_copy "$mstack_dir/browse/bin" "$codex_mstack/browse/bin"
  fi
  if [ -f "$agents_dir/mstack-upgrade/SKILL.md" ]; then
    _link_or_copy "$agents_dir/mstack-upgrade/SKILL.md" "$codex_mstack/mstack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, NOT the whole review/ dir which has SKILL.md)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$mstack_dir/review/$f" ]; then
      _link_or_copy "$mstack_dir/review/$f" "$codex_mstack/review/$f"
    fi
  done
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$mstack_dir/ETHOS.md" ]; then
    _link_or_copy "$mstack_dir/ETHOS.md" "$codex_mstack/ETHOS.md"
  fi
}

create_factory_runtime_root() {
  local mstack_dir="$1"
  local factory_mstack="$2"
  local factory_dir="$mstack_dir/.factory/skills"

  if [ -L "$factory_mstack" ]; then
    rm -f "$factory_mstack"
  elif [ -d "$factory_mstack" ] && [ "$factory_mstack" != "$mstack_dir" ]; then
    rm -rf "$factory_mstack"
  fi

  mkdir -p "$factory_mstack" "$factory_mstack/browse" "$factory_mstack/mstack-upgrade" "$factory_mstack/review"

  if [ -f "$factory_dir/mstack/SKILL.md" ]; then
    _link_or_copy "$factory_dir/mstack/SKILL.md" "$factory_mstack/SKILL.md"
  fi
  if [ -d "$mstack_dir/bin" ]; then
    _link_or_copy "$mstack_dir/bin" "$factory_mstack/bin"
  fi
  if [ -d "$mstack_dir/browse/dist" ]; then
    _link_or_copy "$mstack_dir/browse/dist" "$factory_mstack/browse/dist"
  fi
  if [ -d "$mstack_dir/browse/bin" ]; then
    _link_or_copy "$mstack_dir/browse/bin" "$factory_mstack/browse/bin"
  fi
  if [ -f "$factory_dir/mstack-upgrade/SKILL.md" ]; then
    _link_or_copy "$factory_dir/mstack-upgrade/SKILL.md" "$factory_mstack/mstack-upgrade/SKILL.md"
  fi
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$mstack_dir/review/$f" ]; then
      _link_or_copy "$mstack_dir/review/$f" "$factory_mstack/review/$f"
    fi
  done
  if [ -f "$mstack_dir/ETHOS.md" ]; then
    _link_or_copy "$mstack_dir/ETHOS.md" "$factory_mstack/ETHOS.md"
  fi
}

create_opencode_runtime_root() {
  local mstack_dir="$1"
  local opencode_mstack="$2"
  local opencode_dir="$mstack_dir/.opencode/skills"

  if [ -L "$opencode_mstack" ]; then
    rm -f "$opencode_mstack"
  elif [ -d "$opencode_mstack" ] && [ "$opencode_mstack" != "$mstack_dir" ]; then
    rm -rf "$opencode_mstack"
  fi

  mkdir -p "$opencode_mstack" "$opencode_mstack/browse" "$opencode_mstack/design" "$opencode_mstack/mstack-upgrade" "$opencode_mstack/review" "$opencode_mstack/qa" "$opencode_mstack/plan-devex-review"

  if [ -f "$opencode_dir/mstack/SKILL.md" ]; then
    _link_or_copy "$opencode_dir/mstack/SKILL.md" "$opencode_mstack/SKILL.md"
  fi
  if [ -d "$mstack_dir/bin" ]; then
    _link_or_copy "$mstack_dir/bin" "$opencode_mstack/bin"
  fi
  if [ -d "$mstack_dir/browse/dist" ]; then
    _link_or_copy "$mstack_dir/browse/dist" "$opencode_mstack/browse/dist"
  fi
  if [ -d "$mstack_dir/browse/bin" ]; then
    _link_or_copy "$mstack_dir/browse/bin" "$opencode_mstack/browse/bin"
  fi
  if [ -d "$mstack_dir/design/dist" ]; then
    _link_or_copy "$mstack_dir/design/dist" "$opencode_mstack/design/dist"
  fi
  if [ -f "$opencode_dir/mstack-upgrade/SKILL.md" ]; then
    _link_or_copy "$opencode_dir/mstack-upgrade/SKILL.md" "$opencode_mstack/mstack-upgrade/SKILL.md"
  fi
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$mstack_dir/review/$f" ]; then
      _link_or_copy "$mstack_dir/review/$f" "$opencode_mstack/review/$f"
    fi
  done
  if [ -d "$mstack_dir/review/specialists" ]; then
    _link_or_copy "$mstack_dir/review/specialists" "$opencode_mstack/review/specialists"
  fi
  if [ -d "$mstack_dir/qa/templates" ]; then
    _link_or_copy "$mstack_dir/qa/templates" "$opencode_mstack/qa/templates"
  fi
  if [ -d "$mstack_dir/qa/references" ]; then
    _link_or_copy "$mstack_dir/qa/references" "$opencode_mstack/qa/references"
  fi
  if [ -f "$mstack_dir/plan-devex-review/dx-hall-of-fame.md" ]; then
    _link_or_copy "$mstack_dir/plan-devex-review/dx-hall-of-fame.md" "$opencode_mstack/plan-devex-review/dx-hall-of-fame.md"
  fi
  if [ -f "$mstack_dir/ETHOS.md" ]; then
    _link_or_copy "$mstack_dir/ETHOS.md" "$opencode_mstack/ETHOS.md"
  fi
}

link_factory_skill_dirs() {
  local mstack_dir="$1"
  local skills_dir="$2"
  local factory_dir="$mstack_dir/.factory/skills"
  local linked=()

  if [ ! -d "$factory_dir" ]; then
    echo "  Generating .factory/ skill docs..."
    ( cd "$mstack_dir" && bun run gen:skill-docs --host factory )
  fi

  if [ ! -d "$factory_dir" ]; then
    echo "  warning: .factory/skills/ generation failed — run 'bun run gen:skill-docs --host factory' manually" >&2
    return 1
  fi

  for skill_dir in "$factory_dir"/mstack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "mstack" ] && continue
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        _link_or_copy "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

link_opencode_skill_dirs() {
  local mstack_dir="$1"
  local skills_dir="$2"
  local opencode_dir="$mstack_dir/.opencode/skills"
  local linked=()

  if [ ! -d "$opencode_dir" ]; then
    echo "  Generating .opencode/ skill docs..."
    ( cd "$mstack_dir" && bun run gen:skill-docs --host opencode )
  fi

  if [ ! -d "$opencode_dir" ]; then
    echo "  warning: .opencode/skills/ generation failed — run 'bun run gen:skill-docs --host opencode' manually" >&2
    return 1
  fi

  for skill_dir in "$opencode_dir"/mstack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "mstack" ] && continue
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        _link_or_copy "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# 4. Install for Claude (default)
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    # Clean up stale symlinks from the opposite prefix mode
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      cleanup_old_claude_symlinks "$SOURCE_MSTACK_DIR" "$INSTALL_SKILLS_DIR"
    else
      cleanup_prefixed_claude_symlinks "$SOURCE_MSTACK_DIR" "$INSTALL_SKILLS_DIR"
    fi
    # Patch name: fields BEFORE creating symlinks so link_claude_skill_dirs
    # reads the correct (patched) name: values for symlink naming
    "$SOURCE_MSTACK_DIR/bin/mstack-patch-names" "$SOURCE_MSTACK_DIR" "$SKILL_PREFIX"
    link_claude_skill_dirs "$SOURCE_MSTACK_DIR" "$INSTALL_SKILLS_DIR"
    # Self-healing: re-run mstack-relink to ensure name: fields and directory
    # names are consistent with the config. This catches cases where an interrupted
    # setup, stale git state, or gen:skill-docs left name: fields out of sync.
    MSTACK_RELINK="$SOURCE_MSTACK_DIR/bin/mstack-relink"
    if [ -x "$MSTACK_RELINK" ]; then
      MSTACK_SKILLS_DIR="$INSTALL_SKILLS_DIR" MSTACK_INSTALL_DIR="$SOURCE_MSTACK_DIR" "$MSTACK_RELINK" >/dev/null 2>&1 || true
    fi
    if [ "$LOCAL_INSTALL" -eq 1 ]; then
      log "mstack ready (project-local)."
      log "  skills: $INSTALL_SKILLS_DIR"
    else
      log "mstack ready (claude)."
    fi
    log "  browse: $BROWSE_BIN"
  else
    # Not inside a skills/ directory — would symlink the source into
    # ~/.claude/skills/mstack/ and register from there.
    CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
    CLAUDE_MSTACK_LINK="$CLAUDE_SKILLS_DIR/mstack"

    # Conductor worktree guard: if ~/.claude/skills/mstack is already a real
    # (non-symlink) directory pointing to a *different* install, refuse to plant
    # a symlink there. On macOS/BSD, `ln -snf SRC DST` won't replace a real DST;
    # it creates DST/$(basename SRC) → SRC inside it. The result is per-worktree
    # symlinks leaking into the global install that Claude Code picks up as
    # separate top-level skills (dublin-v1, lincoln-v2, ...). Typical trigger:
    # running ./setup from a Conductor worktree of the mstack repo itself.
    _SKIP_CLAUDE_REGISTER=0
    if [ -d "$CLAUDE_MSTACK_LINK" ] && [ ! -L "$CLAUDE_MSTACK_LINK" ]; then
      _EXISTING_REAL=$(cd "$CLAUDE_MSTACK_LINK" 2>/dev/null && pwd -P || echo "")
      if [ -n "$_EXISTING_REAL" ] && [ "$_EXISTING_REAL" != "$SOURCE_MSTACK_DIR" ]; then
        _SKIP_CLAUDE_REGISTER=1
      fi
    fi

    if [ "$_SKIP_CLAUDE_REGISTER" -eq 1 ]; then
      log ""
      log "  $CLAUDE_MSTACK_LINK already exists as a separate global install."
      log "  Skipping Claude skill registration to avoid polluting it with"
      log "  per-worktree symlinks. (Binaries still built locally for dev.)"
      log ""
      log "    Global install:  $CLAUDE_MSTACK_LINK"
      log "    This worktree:   $SOURCE_MSTACK_DIR"
      log ""
      log "  To register this worktree as the active mstack, remove the global"
      log "  install first:  rm -rf $CLAUDE_MSTACK_LINK"
      log ""
      log "mstack built (claude registration skipped)."
      log "  browse: $BROWSE_BIN"
    else
      mkdir -p "$CLAUDE_SKILLS_DIR"
      _link_or_copy "$SOURCE_MSTACK_DIR" "$CLAUDE_MSTACK_LINK"
      log "  symlinked $CLAUDE_MSTACK_LINK -> $SOURCE_MSTACK_DIR"
      INSTALL_SKILLS_DIR="$CLAUDE_SKILLS_DIR"
      INSTALL_MSTACK_DIR="$CLAUDE_MSTACK_LINK"
      # Clean up stale symlinks from the opposite prefix mode
      if [ "$SKILL_PREFIX" -eq 1 ]; then
        cleanup_old_claude_symlinks "$SOURCE_MSTACK_DIR" "$INSTALL_SKILLS_DIR"
      else
        cleanup_prefixed_claude_symlinks "$SOURCE_MSTACK_DIR" "$INSTALL_SKILLS_DIR"
      fi
      "$SOURCE_MSTACK_DIR/bin/mstack-patch-names" "$SOURCE_MSTACK_DIR" "$SKILL_PREFIX"
      link_claude_skill_dirs "$SOURCE_MSTACK_DIR" "$INSTALL_SKILLS_DIR"
      MSTACK_RELINK="$SOURCE_MSTACK_DIR/bin/mstack-relink"
      if [ -x "$MSTACK_RELINK" ]; then
        MSTACK_SKILLS_DIR="$INSTALL_SKILLS_DIR" MSTACK_INSTALL_DIR="$SOURCE_MSTACK_DIR" "$MSTACK_RELINK" >/dev/null 2>&1 || true
      fi
      log "mstack ready (claude)."
      log "  browse: $BROWSE_BIN"
    fi
  fi
fi

# 5. Install for Codex
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    CODEX_SKILLS="$INSTALL_SKILLS_DIR"
    CODEX_MSTACK="$INSTALL_MSTACK_DIR"
  fi
  mkdir -p "$CODEX_SKILLS"

  # Skip runtime root creation for repo-local installs — the checkout IS the runtime root.
  # create_codex_runtime_root would create self-referential symlinks (bin → bin, etc.).
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_MSTACK_DIR" "$CODEX_MSTACK"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$SOURCE_MSTACK_DIR" "$CODEX_SKILLS"

  log "mstack ready (codex)."
  log "  browse: $BROWSE_BIN"
  log "  codex skills: $CODEX_SKILLS"
fi

# 6. Install for Kiro CLI (copy from .agents/skills, rewrite paths)
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_MSTACK_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # Create mstack dir with symlinks for runtime assets, copy+sed for SKILL.md
  KIRO_MSTACK="$KIRO_SKILLS/mstack"
  # Remove old whole-dir symlink from previous installs
  [ -L "$KIRO_MSTACK" ] && rm -f "$KIRO_MSTACK"
  mkdir -p "$KIRO_MSTACK" "$KIRO_MSTACK/browse" "$KIRO_MSTACK/mstack-upgrade" "$KIRO_MSTACK/review"
  _link_or_copy "$SOURCE_MSTACK_DIR/bin" "$KIRO_MSTACK/bin"
  _link_or_copy "$SOURCE_MSTACK_DIR/browse/dist" "$KIRO_MSTACK/browse/dist"
  _link_or_copy "$SOURCE_MSTACK_DIR/browse/bin" "$KIRO_MSTACK/browse/bin"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$SOURCE_MSTACK_DIR/ETHOS.md" ]; then
    _link_or_copy "$SOURCE_MSTACK_DIR/ETHOS.md" "$KIRO_MSTACK/ETHOS.md"
  fi
  # mstack-upgrade skill
  if [ -f "$AGENTS_DIR/mstack-upgrade/SKILL.md" ]; then
    _link_or_copy "$AGENTS_DIR/mstack-upgrade/SKILL.md" "$KIRO_MSTACK/mstack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, not whole dir)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_MSTACK_DIR/review/$f" ]; then
      _link_or_copy "$SOURCE_MSTACK_DIR/review/$f" "$KIRO_MSTACK/review/$f"
    fi
  done

  # Rewrite root SKILL.md paths for Kiro
  sed -e "s|~/.claude/skills/mstack|~/.kiro/skills/mstack|g" \
      -e "s|\.claude/skills/mstack|.kiro/skills/mstack|g" \
      -e "s|\.claude/skills|.kiro/skills|g" \
      "$SOURCE_MSTACK_DIR/SKILL.md" > "$KIRO_MSTACK/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
  else
    for skill_dir in "$AGENTS_DIR"/mstack*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # Generated Codex skills use $HOME/.codex (not ~/), plus $MSTACK_ROOT variables.
      # Rewrite the default MSTACK_ROOT value and any remaining literal paths.
      sed -e 's|\$HOME/.codex/skills/mstack|$HOME/.kiro/skills/mstack|g' \
          -e "s|~/.codex/skills/mstack|~/.kiro/skills/mstack|g" \
          -e "s|~/.claude/skills/mstack|~/.kiro/skills/mstack|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "mstack ready (kiro)."
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
  fi
fi

# 6b. Install for Factory Droid
if [ "$INSTALL_FACTORY" -eq 1 ]; then
  mkdir -p "$FACTORY_SKILLS"
  create_factory_runtime_root "$SOURCE_MSTACK_DIR" "$FACTORY_MSTACK"
  link_factory_skill_dirs "$SOURCE_MSTACK_DIR" "$FACTORY_SKILLS"
  echo "mstack ready (factory)."
  echo "  browse: $BROWSE_BIN"
  echo "  factory skills: $FACTORY_SKILLS"
fi

# 6c. Install for OpenCode
if [ "$INSTALL_OPENCODE" -eq 1 ]; then
  mkdir -p "$OPENCODE_SKILLS"
  create_opencode_runtime_root "$SOURCE_MSTACK_DIR" "$OPENCODE_MSTACK"
  link_opencode_skill_dirs "$SOURCE_MSTACK_DIR" "$OPENCODE_SKILLS"
  echo "mstack ready (opencode)."
  echo "  browse: $BROWSE_BIN"
  echo "  opencode skills: $OPENCODE_SKILLS"
fi

# 7. Create .agents/ sidecar symlinks for the real Codex skill target.
# The root Codex skill ends up pointing at $SOURCE_MSTACK_DIR/.agents/skills/mstack,
# so the runtime assets must live there for both global and repo-local installs.
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_MSTACK_DIR"
fi

# 8. Run pending version migrations
# Migrations handle state fixes that ./setup alone can't cover (stale config,
# orphaned files, directory structure changes). Each migration is idempotent.
MIGRATIONS_DIR="$SOURCE_MSTACK_DIR/mstack-upgrade/migrations"
CURRENT_VERSION=$(cat "$SOURCE_MSTACK_DIR/VERSION" 2>/dev/null || echo "unknown")
LAST_SETUP_VERSION=$(cat "$HOME/.mstack/.last-setup-version" 2>/dev/null || echo "0.0.0.0")
if [ -d "$MIGRATIONS_DIR" ] && [ "$CURRENT_VERSION" != "unknown" ] && [ "$LAST_SETUP_VERSION" != "$CURRENT_VERSION" ]; then
  # Fresh install (no marker file) — skip migrations, just write marker
  if [ ! -f "$HOME/.mstack/.last-setup-version" ]; then
    : # fall through to marker write below
  else
    find "$MIGRATIONS_DIR" -maxdepth 1 -name 'v*.sh' -type f 2>/dev/null | sort -V | while IFS= read -r migration; do
      m_ver="$(basename "$migration" .sh | sed 's/^v//')"
      # Run if migration is newer than last setup version AND not newer than current version
      if [ "$(printf '%s\n%s' "$LAST_SETUP_VERSION" "$m_ver" | sort -V | head -1)" = "$LAST_SETUP_VERSION" ] && [ "$LAST_SETUP_VERSION" != "$m_ver" ] \
         && [ "$(printf '%s\n%s' "$m_ver" "$CURRENT_VERSION" | sort -V | tail -1)" = "$CURRENT_VERSION" ]; then
        echo "  running migration $m_ver..."
        bash "$migration" || echo "  warning: migration $m_ver had errors (non-fatal)"
      fi
    done
  fi
fi
mkdir -p "$HOME/.mstack"
if [ "$CURRENT_VERSION" != "unknown" ]; then
  echo "$CURRENT_VERSION" > "$HOME/.mstack/.last-setup-version"
fi

